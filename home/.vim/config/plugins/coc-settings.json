{
  "coc.preferences.extensionUpdateCheck": "weekly",
  "coc.preferences.rootPatterns": [".git", ".projections.json", "package.json"],
  "coc.preferences.useQuickfixForLocations": true,
  "coc.source.snippets-source.priority": 100,
  "coc.source.snippets.priority": 100,
  "diagnostic.checkCurrentLine": true,
  "diagnostic.errorSign": "💀",
  "diagnostic.floatConfig": {
    "border": true,
    "borderhighlight": "CocFloatBorder",
    "maxWidth": 160,
    "title": "Diagnostics:"
  },
  "diagnostic.hintSign": "!",
  "diagnostic.infoSign": "i",
  "diagnostic.virtualText": false,
  "diagnostic.virtualTextCurrentLineOnly": true,
  "diagnostic.warningSign": "🤔",
  "floatFactory.floatConfig": {
    "border": true,
    "borderhighlight": "CocFloatBorder",
    "title": "Float:"
  },
  "hover.floatConfig": {
    "border": true,
    "borderhighlight": "CocFloatBorder",
    "title": "Hover:"
  },
  "javascript.format.enabled": false,
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "javascript.preferences.importModuleSpecifierEnding": "js",
  "javascript.preferences.quoteStyle": "double",
  "javascript.updateImportsOnFileMove.enable": "never",
  "languageserver": {
    "terraform": {
      "args": ["serve"],
      "command": "terraform-ls",
      "filetypes": ["terraform", "tf"],
      "initializationOptions": {},
      "settings": {}
    },
    "toml": {
      "args": ["lsp"],
      "command": "tombi",
      "filetypes": ["toml"],
      "initializationOptions": {},
      "settings": {}
    },
    "helm": {
      "command": "helm_ls",
      "args": ["serve"],
      "filetypes": ["helm", "helmfile"],
      "rootPatterns": ["Chart.yaml"]
    }
  },
  "refactor.beforeContext": 1,
  "refactor.afterContext": 1,
  "refactor.openCommand": "split",
  "rust-analyzer.cargo.loadOutDirsFromCheck": true,
  "rust-analyzer.procMacro.enable": true,
  "rust-analyzer.updates.channel": "nightly",
  "snippets.loadFromExtensions": false,
  "snippets.priority": 100,
  "snippets.snipmate.enable": false,
  "snippets.textmateSnippetsRoots": ["~/.vim/config/private_snippets"],
  "snippets.trace": false,
  "snippets.ultisnips.directories": [],
  "snippets.ultisnips.pythonPrompt": false,
  "snippets.userSnippetsDirectory": "~/.vim/config/private_snippets",
  "suggest.autoTrigger": "always",
  "suggest.floatConfig": {
    "border": true,
    "borderhighlight": "CocFloatBorder",
    "title": "Suggest:"
  },
  "suggest.insertMode": "insert",
  "suggest.languageSourcePriority": 89,
  "suggest.maxCompleteItemCount": 20,
  "suggest.minTriggerInputLength": 3,
  "tsserver.formatOnType": false,
  "tsserver.reportStyleChecksAsWarnings": false,
  "tsserver.tsdk": "./node_modules/typescript/lib",
  "tsserver.useLocalTsdk": true,
  "typescript.diagnostics.ignoredCodes": [80004],
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.preferences.importModuleSpecifierEnding": "js",
  "typescript.preferences.includePackageJsonAutoImports": "off",
  "typescript.preferences.preferTypeOnlyAutoImports": true,
  "typescript.referencesCodeLens.enabled": true,
  "typescript.suggest.autoImports": false,
  "volar.disableFormatting": true,
  "vue.inlayHints.missingProps": true,
  "yaml.schemaStore.enable": true,
  "yaml.enable": true,
  "yaml.validate": true,
  "yaml.hover": true,
  "yaml.completion": true,
  "yaml.schemas": {
    "modline-example-in-yaml-files": "# yaml-language-server: $schema=<urlToTheSchema>",
    "actual-url-for-kubernetes": "https://raw.githubusercontent.com/yannh/kubernetes-json-schema/master/v1.34.0-standalone-strict/all.json"
  }
}
